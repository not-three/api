{
  "name": "@not3/api",
  "version": "IN-DEV",
  "description": "!3 is a simple, secure and open source paste sharing platform.",
  "author": "Joschua Becker EDV <support@scolasti.co>",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "LOG_LEVEL=debug nest start --watch",
    "dev:verbose": "LOG_LEVEL=verbose nest start --watch",
    "dev:trace": "LOG_LEVEL=trace nest start --watch",
    "dev:log": "LOG_LEVEL=log nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "build": "npm run build:nest && npm run build:docs",
    "build:nest": "nest build",
    "build:docs": "typedoc",
    "pg:dev": "pnpm pg:reset && pnpm pg:build && pnpm pg:start",
    "pg:base": "docker compose -f docker-compose.db.yml -f docker-compose.override.yml",
    "pg:build": "pnpm pg:base build",
    "pg:start": "pnpm pg:base up",
    "pg:reset": "pnpm pg:base down --volumes"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/s3-presigned-post": "^3.1042.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "cache-manager": "^7.2.8",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "fix-esm": "^1.0.1",
    "ip-regex": "^5.0.0",
    "ipaddr.js": "^2.4.0",
    "knex": "^3.2.10",
    "mysql": "^2.18.1",
    "nanoid": "^5.1.11",
    "p-retry": "^8.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/ip": "^1.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
